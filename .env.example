# TeamCity Configuration
TEAMCITY_URL=https://your-teamcity-instance.com
TEAMCITY_TOKEN=your-teamcity-api-token

# Webhook Security
TEAMCITY_WEBHOOK_SECRET=your-webhook-hmac-secret

# Slack (for failure alerts — used in later phases)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional overrides
# SERVICE_PORT=8000
# CONFIG_PATH=config/settings.yaml
