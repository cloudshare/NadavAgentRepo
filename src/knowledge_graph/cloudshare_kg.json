  "failure_patterns": [
    {
      "id": "vmware_esx_timeout",
      "name": "VMware ESX Timeout",
      "infra_layer": "CSC",
      "category": "infrastructure_instability",
      "description": "VMware ESX host timeout during VM provisioning, power operations, or snapshot tasks",
      "regex_patterns": [
        "(?i)operation timed out.*vmware",
        "(?i)esx.*timeout",
        "(?i)Timeout waiting for.*vm",
        "(?i)Unable to create virtual machine",
        "(?i)clone.*failed.*timeout",
        "(?i)VMware.*timed out",
        "(?i)virtual machine.*not respond",
        "(?i)Task.*timed out"
      ]
    },
    {
      "id": "netapp_nfs_contention",
      "name": "NetApp NFS Contention",
      "infra_layer": "CSC",
      "category": "infrastructure_instability",
      "description": "NetApp NFS datastore unavailable or contended — affects snapshot, CloudFolder mount, and VM storage operations",
      "regex_patterns": [
        "(?i)NFS.*not responding",
        "(?i)stale.*NFS.*file handle",
        "(?i)NFS.*FSINFO failed",
        "(?i)Lost connection.*NFS",
        "(?i)NFS server.*disconnect",
        "(?i)I/O error.*datastore",
        "(?i)NetApp.*timeout",
        "(?i)NFS.*APD",
        "(?i)datastore.*unavailable"
      ]
    },
    {
      "id": "azure_service_bus_delay",
      "name": "Azure Service Bus Delay",
      "infra_layer": "PCS",
      "category": "cloud_provisioning_delay",
      "description": "Azure Service Bus message queue delays or disconnections affecting async environment provisioning",
      "regex_patterns": [
        "(?i)ServiceBusException",
        "(?i)ServiceTimeout.*ServiceBus",
        "(?i)MessageLockLost",
        "(?i)SessionLockLost",
        "(?i)service bus.*timeout",
        "(?i)AMQP.*disconnect",
        "(?i)service bus.*not responding",
        "(?i)ServiceBusy",
        "(?i)ETIMEDOUT.*servicebus",
        "(?i)message delivery.*delay"
      ]
    },
    {
      "id": "aws_sqs_delay",
      "name": "AWS SQS Delay",
      "infra_layer": "PCS",
      "category": "cloud_provisioning_delay",
      "description": "AWS SQS queue delays or errors affecting public cloud provisioning workflows",
      "regex_patterns": [
        "(?i)SQS.*timeout",
        "(?i)QueueDoesNotExist",
        "(?i)AWS.*SQS.*error",
        "(?i)SQS.*connection.*refused",
        "(?i)ReceiveMessage.*timed out",
        "(?i)SQS.*throttl",
        "(?i)RequestThrottled.*sqs"
      ]
    },
    {
      "id": "redis_cache_staleness",
      "name": "Redis Cache Staleness",
      "infra_layer": "WebApp",
      "category": "data_pollution",
      "description": "Redis connection errors or stale cached state causing environment status inconsistency",
      "regex_patterns": [
        "(?i)redis.*ConnectionError",
        "(?i)redis.*TimeoutError",
        "(?i)Connection.*refused.*redis",
        "(?i)redis.*stale",
        "(?i)WRONGTYPE.*redis",
        "(?i)redis.*ERR Connection timed out",
        "(?i)cache.*stale",
        "(?i)stale.*cache.*state",
        "(?i)redis.*Connection closed by server"
      ]
    },
    {
      "id": "vlan_ip_exhaustion",
      "name": "VLAN/IP Exhaustion",
      "infra_layer": "CSC",
      "category": "infrastructure_instability",
      "description": "VLAN or IP address pool exhaustion preventing new environment network allocation",
      "regex_patterns": [
        "(?i)no.*free.*vlan",
        "(?i)vlan.*exhausted",
        "(?i)ip.*exhausted",
        "(?i)out of.*ip.*address",
        "(?i)address.*pool.*empty",
        "(?i)network.*allocation.*failed",
        "(?i)no available.*network",
        "(?i)ip.*allocation.*fail"
      ]
    },
    {
      "id": "predictor_ml_failure",
      "name": "Predictor ML Failure",
      "infra_layer": "Predictor",
      "category": "infrastructure_instability",
      "description": "ML predictor service failure or timeout during pre-warming class environments",
      "regex_patterns": [
        "(?i)predictor.*fail",
        "(?i)ml.*pre.?warm.*fail",
        "(?i)pre.?warming.*timeout",
        "(?i)predictor.*timeout",
        "(?i)warmup.*fail",
        "(?i)predictor.*error",
        "(?i)class.*start.*slow",
        "(?i)pre-warm.*not.*complete"
      ]
    },
    {
      "id": "rbac_jwt_expiry",
      "name": "RBAC/JWT Expiry",
      "infra_layer": "WebApp",
      "category": "auth_session_issue",
      "description": "JWT token expiry or RBAC authorization failure on protected endpoints",
      "regex_patterns": [
        "(?i)jwt.*expired",
        "(?i)token.*expired",
        "(?i)401.*Unauthorized",
        "(?i)403.*Forbidden",
        "(?i)jwt.*invalid",
        "(?i)access.*denied",
        "(?i)role.*not.*permitted",
        "(?i)RBAC.*fail",
        "(?i)authentication.*failed",
        "(?i)Invalid JWT",
        "(?i)token.*not.*valid"
      ]
    },
    {
      "id": "aws_ami_sharing",
      "name": "AWS AMI Sharing Failure",
      "infra_layer": "PCS",
      "category": "cloud_provisioning_delay",
      "description": "AWS AMI image not yet shared or available in target region for public cloud VM creation",
      "regex_patterns": [
        "(?i)AMI.*not.*available",
        "(?i)ami.*sharing.*fail",
        "(?i)image.*not.*found.*aws",
        "(?i)AMI.*pending"
      ]
    },
    {
      "id": "terraform_failure",
      "name": "Terraform Apply Failure",
      "infra_layer": "PCS",
      "category": "cloud_provisioning_delay",
      "description": "Terraform infrastructure-as-code apply failure during public cloud environment provisioning",
      "regex_patterns": [
        "(?i)terraform.*error",
        "(?i)terraform.*fail",
        "(?i)terraform apply.*failed",
        "(?i)Error applying plan"
      ]
    },
    {
      "id": "eventual_consistency",
      "name": "Eventual Consistency Race",
      "infra_layer": "PCS",
      "category": "race_condition",
      "description": "Race condition where resource is not yet propagated across distributed systems — retry typically resolves",
      "regex_patterns": [
        "(?i)eventual.*consistency",
        "(?i)resource.*not.*yet.*available",
        "(?i)provisioning.*still.*in.*progress",
        "(?i)environment.*not.*ready"
      ]
    }
  ]
